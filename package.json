{
  "name": "pi-committer",
  "version": "0.1.6",
  "description": "Conventional commit automation for the pi coding agent — auto-commits on goal completion with intelligent, subagent-generated messages",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "test": "node --experimental-strip-types --test tests/unit.test.ts",
    "test:e2e": "PI_COMMITTER_E2E=1 node --experimental-strip-types --test tests/e2e.test.ts",
    "test:all": "node --experimental-strip-types --test tests/*.test.ts"
  },
  "author": "pi-committer contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tmonk/pi-committer.git"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "pi-package",
    "git",
    "conventional-commits",
    "automation"
  ],
  "dependencies": {
    "smol-toml": "^1.3.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "https://github.com/tmonk/pi-committer/raw/main/screenshot.png"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  }
}
